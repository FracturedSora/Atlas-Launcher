{
  "name": "atlas-launcher",
  "version": "1.0.0",
  "description": "The official source code for atlas launcher",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FracturedSora/Atlas-Launcher.git"
  },
  "author": "FracturedSora",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/FracturedSora/Atlas-Launcher/issues"
  },
  "homepage": "https://github.com/FracturedSora/Atlas-Launcher#readme",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "path": "^0.12.7",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.atlas.launcher",
    "productName": "Atlas Launcher",
    "files": [
      "**/*",
      ".env",
      "!dist/*",
      "!node_modules/*"
    ],
    "asar": true,
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Other"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
