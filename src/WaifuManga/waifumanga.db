    "Attack on Titan": {
      "id": 53390,
      "title": {
        "english": "Attack on Titan",
        "romaji": "Shingeki no Kyojin",
        "native": "進撃の巨人"
      },
      "synonyms": [
        "Atak Tytanów",
        "SnK",
        "AoT",
        "Ataque dos Titãs",
        "Ataque a los Titanes",
        "L'Attacco dei Giganti",
