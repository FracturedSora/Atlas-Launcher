    "180209": {
      "id": 180209,
      "title": {
        "english": null,
        "romaji": "Inaho-kun wa Nise Kanojo no Hazu Nano ni",
        "native": "稲穂くんは偽カノジョのはずなのに"
      },
      "synonyms": [
        "Inaho-kun Is Supposed to Be a Fake Sweetheart"
      ],
      "description": "Shintarou Mori, a first-year high school boy, is teased by his friends for wanting to find a beautiful girlfriend and having a sparkling social life. His classmate Inaho Sawatari is regarded as the smartest and most beautiful girl in school. The two of them shouldn't have anything to do with eacher, but when they're inadvertently mistaken for a couple, Inaho proposes: \"How about we pretend we're really dating?\" They act like a couple in public, but it turns out the most beautiful girl in the school is actually a very cute boy...!\n<br><br>\n(Source: Earth Star Entertainment, translated)",
