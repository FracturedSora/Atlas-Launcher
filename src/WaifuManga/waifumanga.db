    "Haimiya-senpai wa Kowakute Kawaii": {
      "id": 201773,
      "title": {
        "english": null,
        "romaji": "Haimiya-senpai wa Kowakute Kawaii",
        "native": "灰宮先輩は怖くてかわいい"
      },
      "synonyms": [
        "Haimiya Senpai is Scary but Cute"
      ],
      "description": "Haimiya-senpai is feared around school for her intimidating appearance and blunt way of speaking... Sparkling piercings! Bleached-gray wolf-cut hair!! And speaking in the Kansai dialect!!! But for some reason, this scary senpai always seems to treat me kindly—!? See how “scary” turns into “cute” in this romantic comedy!\n<BR><BR>\n(Source: Square Enix, translated)",
      "status": "RELEASING",
      "startDate": {
        "year": 2025,
        "month": 11,
        "day": 6
      },
